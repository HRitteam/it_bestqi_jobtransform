# ===================================================================
# Git 策略（本地构建 + Git 推送产物 模式）
# 允许提交打包产物（dist/、build/、.next/），但继续忽略 node_modules
# ===================================================================

# Dependencies（始终忽略，服务器用 pnpm install --prod 安装）
**/node_modules
.pnpm-store/

# ---- 构建产物：允许提交（部署模式要求）----
# 注意：dist/ build/ .next/ 不再忽略，需随源码一并推送到 Git

# Environment variables（敏感信息，绝不提交）
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock
*.bak

# Coverage directory used by tools like istanbul
coverage/
*.lcov

# nyc test coverage
.nyc_output

# Dependency directories
jspm_packages/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# parcel-bundler cache (https://parceljs.org/)
.cache
.parcel-cache

# Nuxt.js build / generate output
.nuxt

# Gatsby files
.cache/

# Storybook build outputs
.out
.storybook-out

# Temporary folders
tmp/
temp/

# Database
*.db
*.sqlite
*.sqlite3

# Webdev artifacts (checkpoint zips, migrations, etc.)
.webdev/

# Manus version file (auto-generated, not part of source)
client/public/__manus__/version.json
